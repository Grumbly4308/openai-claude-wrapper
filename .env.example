# Claude Code authentication.
#
# Preferred: don't set either of these. Instead run a one-time interactive
# login that persists credentials to the claude-home volume:
#
#   docker compose run --rm -it claude-wrapper login
#   # or, for a long-lived token suitable for headless use:
#   docker compose run --rm -it claude-wrapper setup-token
#
# Set these env vars only if you want to bypass the interactive flow
# entirely (e.g. CI) and use API-key / pre-minted token auth.
ANTHROPIC_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=

# Comma-separated API keys clients must pass as "Authorization: Bearer <key>".
# Leave empty to run without auth (only safe on a trusted network).
CLAUDE_WRAPPER_API_KEYS=

# Port to listen on. The server is always bound to 0.0.0.0 inside the
# container and published to 0.0.0.0:<this port> on the host, so it is
# reachable from any interface (LAN, docker network, localhost).
CLAUDE_WRAPPER_PORT=8000

# Default model when clients send "auto" (or no model).
CLAUDE_WRAPPER_DEFAULT_MODEL=claude-opus-4-8

# How /v1/models builds its list, once, at startup:
#   auto (default) — scan the installed `claude` binary for the model ids it
#                    knows about (canonical <family>-<major>-<minor>, plus the
#                    [1m] long-context variants), so the list tracks whatever
#                    Claude Code version is installed.
#   off            — skip the scan and serve a static built-in fallback list.
# Discovery falls back to the static list automatically if the binary can't be
# read. The default model above is always included regardless.
CLAUDE_WRAPPER_MODEL_DISCOVERY=auto

# Reasoning effort forwarded to `claude` on every request:
# low | medium | high | xhigh | max are passed as `--effort <level>`.
# "ultracode" is also accepted — it requests xhigh effort plus ultracode's
# dynamic-workflow orchestration opt-in via `--settings` (not `--effort`).
# Applies to Opus 4.5+ models. Leave blank to use the CLI's own default effort.
# This is the fallback for requests that DON'T pick an effort variant (i.e. the
# client sends the bare model id). Pick a per-request level in the client by
# selecting an advertised variant like "claude-opus-4-8 (high)". The resolved
# level is logged per request as `effort=<level> (request|server-default)`.
CLAUDE_WRAPPER_EFFORT=medium

# Upload ceiling in bytes (default 2 GiB). Raise for very large video files.
CLAUDE_WRAPPER_MAX_UPLOAD_BYTES=2147483648

# Per-request timeout in seconds (default 30 minutes).
CLAUDE_WRAPPER_REQUEST_TIMEOUT=1800

# ---- Optional: streaming feedback (long-running / high-effort prompts) ----
# On a hard problem at high/max/ultracode effort, Claude can think or run tools
# for many minutes before any answer text. These keep the SSE stream alive AND
# visible in the client feed so it doesn't look stalled (and so a buffering
# reverse proxy doesn't sever a connection that hasn't sent visible bytes yet).
#
# Seconds between lightweight keep-alive comments (socket warmth).
CLAUDE_WRAPPER_SSE_HEARTBEAT=15
# Bytes of comment padding sent once at stream start to force a buffering proxy
# to flush the response head immediately (prevents the client hanging before it
# ever receives HTTP headers). Set 0 to disable.
CLAUDE_WRAPPER_SSE_PREAMBLE_BYTES=2048
# Seconds of silence before emitting a VISIBLE "still working… (elapsed)" tick on
# the reasoning channel. Real data — shows life in the feed and flushes proxies a
# bare comment wouldn't. Set 0 to disable.
CLAUDE_WRAPPER_SSE_PROGRESS_SECONDS=25
# Surface tool/subagent activity (e.g. "🔧 Bash: …") in the feed as reasoning
# content, so a tool-heavy phase shows progress. Set false to hide it.
CLAUDE_WRAPPER_SSE_SHOW_ACTIVITY=true
# Channel for reasoning/progress frames (thinking, tool activity, the "still
# working" tick). NOTE: Open WebUI treats this wrapper as an "openai" provider and
# renders NO native reasoning for openai (it ignores both reasoning_content and
# inline <think>), so the content-wrapped "details" mode is the default.
#   details           — <details type="reasoning"> block in the content stream;
#                       OWUI's own reasoning representation, renders as a
#                       collapsible panel for any provider. Needs an effort-enabled
#                       model so thinking is actually emitted. (default)
#   reasoning_content — structured DeepSeek-R1 delta field; renders natively only
#                       on providers OWUI recognizes for it (e.g. llama.cpp).
#   think_tags        — inline <think>…</think> in content; ollama-provider only.
#   none              — suppress reasoning/progress entirely (answer text only).
CLAUDE_WRAPPER_REASONING_CHANNEL=details
# Stream text/thinking token-by-token (live) via `--include-partial-messages`
# instead of one whole block per reasoning step. Set off for whole-block events.
CLAUDE_WRAPPER_STREAM_PARTIAL=true

# ---- Optional: interactive clarification protocol ----
# Headless Claude Code has no interactive question UI, so its AskUserQuestion
# card gets auto-dismissed and Claude proceeds on assumptions — you never get to
# answer. With this ON (default) the wrapper injects a system prompt teaching
# Claude to, when a decision genuinely changes the result, ask its questions as
# plain numbered text and STOP, so you answer in your next message (the session
# resumes automatically). It also disables the dead AskUserQuestion tool. Only
# affects chat/responses; delegated task endpoints (audio/images/…) never pause.
# Per-request override: send "clarify": false in the chat body to opt out.
CLAUDE_WRAPPER_CLARIFY=on
# Tools to disable so questions come as answerable text, not a dead card.
CLAUDE_WRAPPER_CLARIFY_DISALLOWED_TOOLS=AskUserQuestion
# Override the injected instruction entirely (leave blank to use the built-in).
CLAUDE_WRAPPER_CLARIFY_PROMPT=

# ---- Optional: per-conversation token cap (usage checkpoint) ----
# Stops a single conversation from quietly burning your whole session quota.
# Each conversation may spend ALLOWANCE x PERCENT tokens (a "block") before the
# wrapper pauses and replies with a checkpoint message instead of calling Claude.
# Reply with a continue keyword to grant one more block; starting a NEW chat
# resets the count (a new conversation = a fresh budget).
#
# The cap is ON by default at the Max 5x ($100) plan. Two ways to set the
# allowance (an explicit number wins over a plan):
#
# (a) By subscription plan. Anthropic doesn't publish per-plan token figures, so
#     this is an ESTIMATE anchored on a tunable "Pro session tokens" value, with
#     Max derived as 5x ($100) and 20x ($200) of Pro — matching how the plans are
#     marketed. Accepts: pro | pro $20 | max 5x | max $100 | max 20x | max $200.
#     Set it to "off" (or "none"/"disabled") to turn the cap off entirely.
CLAUDE_WRAPPER_SESSION_PLAN=max 5x
# Tokens per session for the Pro tier; Max plans scale 5x/20x from this. The
# default 1500000 is calibrated from real usage (a heavy ~2h session = ~1.54M
# billable tokens = 21% of a Max-5x window). Tune to taste.
CLAUDE_WRAPPER_PRO_SESSION_TOKENS=1500000
#
# (b) Directly, bypassing the plan math. Set one "session's worth" of tokens.
#     Leave 0 to use the plan above.
CLAUDE_WRAPPER_SESSION_TOKEN_ALLOWANCE=0
# Block size as a percentage of the allowance (default 5 => 5% per checkpoint).
CLAUDE_WRAPPER_SESSION_BLOCK_PERCENT=5
# Comma-separated keywords (case-insensitive) that resume a paused conversation.
CLAUDE_WRAPPER_BUDGET_CONTINUE_KEYWORD=continue,proceed,keep going,go on,yes

# uvicorn worker processes. Leave at 1 — concurrency comes from async I/O.
CLAUDE_WRAPPER_WORKERS=1

# ---- Optional: OpenWebUI knowledge-base passthrough ----
# When OPENWEBUI_BASE_URL is set, every request to the wrapper gets a
# system-prompt addendum teaching Claude to query the OpenWebUI retrieval
# API via Bash + curl. The api key flows to Claude's Bash tool through
# env passthrough — it is never written into the user-visible prompt.
#
# Leave OPENWEBUI_BASE_URL blank to disable this entirely.
OPENWEBUI_BASE_URL=
OPENWEBUI_API_KEY=
# Optional default collection. Set this to a knowledge-base ID (the `id`
# field from GET /api/v1/knowledge/), NOT its display name — the retrieval
# /query/collection endpoint matches on id. If set, the model biases toward
# it when nothing more specific is requested (and can still resolve a name to
# an id via the discovery step). Leave blank to make the model always discover.
OPENWEBUI_DEFAULT_COLLECTION=
